    "keywords": [
        "wiji",
        "uuid",
        "ulid",
        "unique-id",
        "identifier",
        "timestamp",
        "monotonic",
        "sangkan"
    ],
    "homepage": "https://sangkan.dev",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/sangkan-dev/wiji/issues",
        "source": "https://github.com/sangkan-dev/wiji"
    },
    "require": {
        "php": ">=7.3"
    },
    "authors": [
        {
            "name": "Sangkan",
            "email": "hello@sangkan.dev",
            "homepage": "https://sangkan.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "Sangkan\\Wiji\\": "php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sangkan\\Wiji\\Tests\\": "php/tests/"
        }
    },
    "scripts": {
        "test": "php php/tests/WijiTest.php"
    },
    "config": {
        "sort-packages": true
    }
}
